{
  "_comment": "Noise filter patterns for path_search_diff.py file diffs. Each group is selectable in the UI.",
  "default": {
    "description": "Suppress common time-varying fields with no forwarding relevance",
    "patterns": [
      "\\b\\d+\\s+(year|week|day|hour|minute|second|min|sec|hr)s?\\b",
      "\\b\\d{1,2}:\\d{2}:\\d{2}\\b",
      "\\bage\\b",
      "\\buptime\\b",
      "\\blast.change\\b",
      "\\blast.cleared\\b",
      "\\blast.input\\b",
      "\\blast.output\\b",
      "\\binput rate\\b",
      "\\boutput rate\\b",
      "\\brate\\b.*\\bpps\\b",
      "\\brate\\b.*\\bbps\\b",
      "\\bpackets input\\b",
      "\\bpackets output\\b",
      "\\bbytes input\\b",
      "\\bbytes output\\b",
      "\\binput errors\\b",
      "\\boutput errors\\b",
      "\\bno buffer\\b",
      "\\bcrc\\b",
      "\\bframe\\b.*\\berror\\b",
      "\\boverrun\\b",
      "\\bignored\\b",
      "\\bwatchdog\\b",
      "\\bcollisions\\b",
      "\\blate.collision\\b",
      "\\bdeferred\\b",
      "\\blost.carrier\\b",
      "\\bno.carrier\\b",
      "\\boutput.buffer.failure\\b",
      "\\boutput.buffers.swapped\\b",
      "\\bqueue.drops\\b",
      "\\b5 minute\\b",
      "\\b30 second\\b",
      "\\bHardware is\\b.*\\baddress is\\b",
      "snapshot_time",
      "^\\s*$"
    ]
  },
  "strict": {
