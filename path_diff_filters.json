  "_comment_concurrency": "Number of devices analysed in parallel. Increase to speed up analysis on well-resourced instances. Default 10. Set to 1 to disable parallelism.",
  "concurrency": 30,
  "_comment_lineTransforms": "Pre-diff line transforms: strip volatile fragments before comparing lines. Each entry has 'pattern' (regex), 'replacement' (string), and 'description'. Applied to both old and new lines before difflib runs \u2014 so only the remaining content is compared. Useful when a line has both meaningful and noisy fields.",
  "lineTransforms": [
    {
      "description": "HSRP: strip 'expires in X.X sec(s)' \u2014 keeps IP/priority visible if they change",
      "pattern": ",?\\s*expires in [\\d\\.]+\\s*sec\\w*(\\s*\\(\\w+\\))?",
      "replacement": ""
    },
    {
      "description": "MAC table: strip trailing age timestamp \u2014 keeps VLAN/MAC/interface/port visible",
      "pattern": "\\s+(?:\\d+\\s+days?,\\s*)?\\d+:\\d{2}:\\d{2}\\s+ago\\s*$",
      "replacement": ""
    },
    {
      "description": "OSPF: strip checksum sum fragment \u2014 keeps LSA count visible if it changes",
      "pattern": ",?\\s*Checksum\\s+[Ss]um\\s+\\d+",
      "replacement": ""
    }
  ]
}